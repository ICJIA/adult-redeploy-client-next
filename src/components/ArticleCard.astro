---
interface Props {
  title: string;
  badge?: string;
  pagefindMeta?: Record<string, string>;
}
const { title, badge, pagefindMeta } = Astro.props;
const metaPairs = Object.entries(pagefindMeta ?? {});
---
<article
  data-pagefind-body
  data-pagefind-meta={metaPairs.length > 0
    ? metaPairs.map(([k, v]) => `${k}:${v}`).join(', ')
    : undefined}
  class="max-w-4xl mx-auto my-8 bg-surface shadow-elev1 rounded
         overflow-hidden"
>
  <header class="bg-brand-primary text-white px-6 sm:px-10 py-5
                 flex items-start justify-between gap-4">
    <h1 data-live="title"
        class="font-heading font-black uppercase tracking-tight
               text-lg sm:text-xl md:text-2xl leading-tight">
      {title}
    </h1>
    {badge && (
      <!-- Compact category marker, upper-right of the card. Just a visual
           tag — small + width-capped so long committee names stay unobtrusive.
           Full bg-brand-secondary kept (no opacity) to preserve contrast. -->
      <span data-live="badge"
            class="shrink-0 inline-block bg-brand-secondary text-white
                   text-[10px] font-semibold uppercase tracking-wide
                   px-2 py-1 rounded max-w-[42%] text-right leading-snug">
        {badge}
      </span>
    )}
  </header>
  <div class="px-6 sm:px-10 py-8">
    <slot />
  </div>
</article>
