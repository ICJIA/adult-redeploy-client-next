---
import { getCollection, type CollectionEntry } from 'astro:content';
import { renderHomeNews, NEWS_SIG_KEYS, type NewsRow } from '../lib/live/render/home-news';
import { stableSignature } from '../lib/live/behavior/signature';

type News = CollectionEntry<'news'>['data'];

const newsEntries = await getCollection('news');
const items = newsEntries
  .map((e) => e.data)
  .filter((n: News) => n.publicationDate)
  .sort((a: News, b: News) =>
    (a.publicationDate ?? '') < (b.publicationDate ?? '') ? 1 : -1)
  .slice(0, 4) as unknown as NewsRow[];

const base = import.meta.env.BASE_URL || '/adultredeploy';
const ctx = { endpoint: '', basePath: base };
// Same render fn drives the static markup (set:html) and the live swap, so they
// can't diverge. Baseline signature lets the island skip no-op refreshes.
const sig = stableSignature(items, NEWS_SIG_KEYS);
const xData = `liveCollection({ surface: 'homeNews', sig: ${JSON.stringify(sig)} })`;
---
<section x-data={xData}>
  <h2 class="text-page-title">
    <a href={`${base}/news`}
       class="text-brand-ink hover:text-brand-muted underline-offset-4 hover:underline
              focus-visible:outline focus-visible:outline-2
              focus-visible:outline-brand-primary focus-visible:outline-offset-2">
      ARI NEWS
    </a>
  </h2>
  <ul class="mt-6 space-y-4" x-ref="region" set:html={renderHomeNews(items, ctx)}></ul>
</section>
