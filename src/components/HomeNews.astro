---
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/dates';
import { NEWS_CLASSES, NEWS_SIG_KEYS, type NewsRow } from '../lib/live/render/home-news';
import { stableSignature } from '../lib/live/behavior/signature';

type News = CollectionEntry<'news'>['data'];

const newsEntries = await getCollection('news');
const items: News[] = newsEntries
  .map((e) => e.data)
  .filter((n: News) => n.publicationDate)
  .sort((a: News, b: News) =>
    (a.publicationDate ?? '') < (b.publicationDate ?? '') ? 1 : -1)
  .slice(0, 4);

const base = import.meta.env.BASE_URL || '/adultredeploy';

// Baseline signature of the build-time rows. The live island compares this to
// the freshly-fetched signature and only swaps + announces on a real change.
const sig = stableSignature(items as unknown as NewsRow[], NEWS_SIG_KEYS);
const xData = `liveCollection({ surface: 'homeNews', sig: ${JSON.stringify(sig)} })`;
---
<section x-data={xData}>
  <h2 class="text-page-title">
    <a href={`${base}/news`}
       class="text-brand-ink hover:text-brand-muted underline-offset-4 hover:underline
              focus-visible:outline focus-visible:outline-2
              focus-visible:outline-brand-primary focus-visible:outline-offset-2">
      ARI NEWS
    </a>
  </h2>
  <ul class="mt-6 space-y-4" x-ref="region">
    {items.map((item: News) => (
      <li class={NEWS_CLASSES.li}>
        <div class={NEWS_CLASSES.date}>
          Posted: {formatDate(item.publicationDate)}
        </div>
        <h3 class={NEWS_CLASSES.h3}>
          <a href={`${base}/news/${item.slug}`} class={NEWS_CLASSES.link}>
            {item.title}
          </a>
        </h3>
        {item.summary && <p class={NEWS_CLASSES.summary}>{item.summary}</p>}
      </li>
    ))}
  </ul>
</section>
