---
const base = import.meta.env.BASE_URL || '/adultredeploy';
const boxes = [
  {
    href: `${base}/programs`,
    title: 'Programs',
    text: 'ARI is based on local control and design because communities know best how to protect public safety and reduce recidivism.',
    icon: 'users',
  },
  {
    href: `${base}/grants`,
    title: 'Grants',
    text: 'ARI uses "performance incentive funding" to support local investment in more effective and less expensive alternatives to incarceration.',
    icon: 'money',
  },
  {
    href: `${base}/resources`,
    title: 'Resources',
    text: 'ARI provides training and technical assistance, collects and analyzes data, and fosters a statewide learning community.',
    icon: 'cogs',
  },
];
---
<!-- Full-bleed band: the green spans edge-to-edge (no max-width gutters); the
     paragraph below is width-capped so line length stays readable on wide screens. -->
<div class="grid gap-0 md:grid-cols-3">
  {boxes.map((b) => (
    <a href={b.href}
       class="block bg-brand-primary text-white px-8 py-10 text-center
              hover:bg-brand-primary/90 transition
              focus-visible:outline focus-visible:outline-2
              focus-visible:outline-white focus-visible:outline-offset-[-4px]">
      <div class="flex justify-center mb-4" aria-hidden="true">
        {b.icon === 'users' && (
          <svg width="56" height="56" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
          </svg>
        )}
        {b.icon === 'money' && (
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="6" width="20" height="12" rx="1.5" />
            <circle cx="12" cy="12" r="3" />
            <path d="M6 12h.01M18 12h.01" stroke-linecap="round"/>
          </svg>
        )}
        {b.icon === 'cogs' && (
          <svg width="56" height="56" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.43 12.98c.04-.32.07-.64.07-.98 0-.34-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98 0 .33.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"/>
          </svg>
        )}
      </div>
      <h2 class="font-heading font-black text-2xl uppercase tracking-wide mb-3">
        {b.title}
      </h2>
      <p class="text-sm leading-relaxed text-on-primary-soft max-w-sm mx-auto">{b.text}</p>
    </a>
  ))}
</div>
