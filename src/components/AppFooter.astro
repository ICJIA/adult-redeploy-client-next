---
import { Image } from 'astro:assets';
import logo from '../assets/icjia-logo.png';

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL || '/adultredeploy';
const currentPath = Astro.url.pathname.replace(base, '') || '/';

const navItems = [
  { label: 'About',     href: `${base}/about`,     match: '/about' },
  { label: 'Approach',  href: `${base}/approach`,  match: '/approach' },
  { label: 'Programs',  href: `${base}/programs`,  match: '/programs' },
  { label: 'Grants',    href: `${base}/grants`,    match: '/grants' },
  { label: 'News',      href: `${base}/news`,      match: '/news' },
  { label: 'Resources', href: `${base}/resources`, match: '/resources' },
  { label: 'Sites',     href: `${base}/sites`,     match: '/sites' },
  { label: 'Apps',      href: `${base}/apps`,      match: '/apps' },
  { label: 'Search',    href: `${base}/search`,    match: '/search' },
];
const isActive = (m: string) =>
  currentPath === m || currentPath.startsWith(`${m}/`);
---
<footer class="noprint bg-brand-primary text-white mt-12 print:hidden"
        aria-label="Site footer">
  <nav aria-label="Footer navigation"
       class="border-b border-white/10">
    <ul class="max-w-7xl mx-auto px-4 py-3 flex flex-wrap items-center
               justify-center gap-x-1 gap-y-2">
      {navItems.map((item) => (
        <li>
          <a href={item.href}
             class:list={[
               'inline-block px-4 py-2 text-sm font-bold uppercase tracking-wider',
               'hover:bg-white/10 rounded transition',
               'focus-visible:outline focus-visible:outline-2',
               'focus-visible:outline-white focus-visible:outline-offset-2',
               isActive(item.match) && 'bg-white/15',
             ]}
             aria-current={isActive(item.match) ? 'page' : undefined}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="py-10 flex flex-col items-center gap-6">
    <a href="https://icjia.illinois.gov"
       aria-label="Illinois Criminal Justice Information Authority"
       class="inline-block rounded
              focus-visible:outline focus-visible:outline-2
              focus-visible:outline-white focus-visible:outline-offset-4">
      <Image src={logo}
             alt="Illinois Criminal Justice Information Authority"
             widths={[120, 240]}
             sizes="120px"
             formats={['webp']}
             loading="lazy"
             class="block h-auto w-[120px]" />
    </a>

    <ul class="flex items-center gap-4">
      <li>
        <a href="https://www.facebook.com/ICJIA"
           aria-label="ICJIA on Facebook"
           class="block p-1 rounded
                  focus-visible:outline focus-visible:outline-2
                  focus-visible:outline-white focus-visible:outline-offset-2">
          <svg width="22" height="22" viewBox="0 0 24 24"
               fill="currentColor" aria-hidden="true">
            <path d="M22 12a10 10 0 1 0-11.6 9.9V14.9H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.2c-1.2 0-1.6.7-1.6 1.5V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12Z"/>
          </svg>
        </a>
      </li>
      <li>
        <a href="https://twitter.com/icjia_illinois"
           aria-label="ICJIA on Twitter"
           class="block p-1 rounded
                  focus-visible:outline focus-visible:outline-2
                  focus-visible:outline-white focus-visible:outline-offset-2">
          <svg width="22" height="22" viewBox="0 0 24 24"
               fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </li>
    </ul>
  </div>

  <div class="border-t border-white/10">
    <p class="max-w-7xl mx-auto px-4 py-4 text-xs text-center text-white/80">
      © {year} <a href="https://icjia.illinois.gov" class="underline hover:no-underline">Illinois Criminal Justice Information Authority</a>
      <span aria-hidden="true" class="mx-2">|</span>
      <a href="https://archive.icjia.cloud" class="underline hover:no-underline">ICJIA Document Archive</a>
      <span aria-hidden="true" class="mx-2">|</span>
      <a href="https://doit.illinois.gov/initiatives/accessibility/iitaa.html" class="underline hover:no-underline">Accessibility</a>
    </p>
  </div>
</footer>
