---
import { getCollection } from 'astro:content';
import { renderHomeMeetings, HOME_MTG_SIG_KEYS, selectUpcoming, type MeetingRow } from '../lib/live/render/home-meetings';
import { stableSignature } from '../lib/live/behavior/signature';

const meetingEntries = await getCollection('meetings');
const upcoming = selectUpcoming(meetingEntries.map((e) => e.data), 4) as unknown as MeetingRow[];

const base = import.meta.env.BASE_URL || '/adultredeploy';
const ctx = { endpoint: '', basePath: base };
const sig = stableSignature(upcoming, HOME_MTG_SIG_KEYS);
const xData = `liveCollection({ surface: 'homeMeetings', sig: ${JSON.stringify(sig)} })`;
---
<section x-data={xData}>
  <h2 class="text-page-title">
    <a href={`${base}/about/meetings`}
       class="tap-target text-brand-ink hover:text-brand-ink-muted underline-offset-4 hover:underline
              focus-visible:outline focus-visible:outline-2
              focus-visible:outline-brand-primary focus-visible:outline-offset-2">
      UPCOMING MEETINGS
    </a>
  </h2>
  <div x-ref="region" set:html={renderHomeMeetings(upcoming, ctx)}></div>
</section>
