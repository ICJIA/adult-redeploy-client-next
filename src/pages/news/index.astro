---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/ui/PageTitle.astro';
import ListingTable from '../../components/alpine/ListingTable.astro';
import { newsIndexRows, NEWS_INDEX_SIG_KEYS } from '../../lib/live/render/listing-rows';
import { stableSignature } from '../../lib/live/behavior/signature';

const entries = await getCollection('news');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const ctx = { endpoint: '', basePath: base };
// Shared row builder drives both the static table and the live refresh.
const rows = newsIndexRows(entries.map((e) => e.data), ctx);
const live = { surface: 'newsIndex', sig: stableSignature(rows, NEWS_INDEX_SIG_KEYS) };
---
<BaseLayout title="News"
            description="Updates, announcements, and stories from the Adult Redeploy Illinois network.">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <PageTitle title="News Archive" />
    <ListingTable
      ariaLabel="news"
      columns={[
        { key: 'publicationDate', label: 'Posted', format: 'date' },
        { key: 'title',           label: 'Title' },
      ]}
      rows={rows}
      live={live}
    />
  </div>
</BaseLayout>
