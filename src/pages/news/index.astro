---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ListingTable from '../../components/alpine/ListingTable.astro';

type News = CollectionEntry<'news'>['data'];

const entries = await getCollection('news');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const rows = entries
  .map((e) => e.data)
  .sort((a: News, b: News) =>
    (a.publicationDate ?? a.createdAt) < (b.publicationDate ?? b.createdAt) ? 1 : -1)
  .map((n: News) => ({
    title: n.title,
    publicationDate: n.publicationDate ?? n.createdAt,
    href: `${base}/news/${n.slug}`,
  }));
---
<BaseLayout title="News">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home', href: `${base}/` },
      { label: 'News' },
    ]} />
    <h1 class="text-page-title mt-4">News</h1>
    <p class="mt-3 text-lg">
      Updates, announcements, and stories from the Adult Redeploy Illinois
      network.
    </p>
    <div class="mt-8">
      <ListingTable
        ariaLabel="news"
        columns={[
          { key: 'title',           label: 'Title' },
          { key: 'publicationDate', label: 'Posted', format: 'date' },
        ]}
        rows={rows}
      />
    </div>
  </div>
</BaseLayout>
