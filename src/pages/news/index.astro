---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/ui/PageTitle.astro';
import ListingTable from '../../components/alpine/ListingTable.astro';

type News = CollectionEntry<'news'>['data'];

const entries = await getCollection('news');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const rows = entries
  .map((e) => e.data)
  .sort((a: News, b: News) =>
    (a.publicationDate ?? a.createdAt) < (b.publicationDate ?? b.createdAt) ? 1 : -1)
  .map((n: News) => ({
    publicationDate: n.publicationDate ?? n.createdAt,
    title: n.title,
    href: `${base}/news/${n.slug}`,
  }));
---
<BaseLayout title="News"
            description="Updates, announcements, and stories from the Adult Redeploy Illinois network.">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <PageTitle title="News Archive" />
    <ListingTable
      ariaLabel="news"
      columns={[
        { key: 'publicationDate', label: 'Posted', format: 'date' },
        { key: 'title',           label: 'Title' },
      ]}
      rows={rows}
    />
  </div>
</BaseLayout>
