---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Markdown from '../../components/Markdown.astro';
import { getCmsImageByPath } from '../../lib/cms-image';

type Bio = CollectionEntry<'biographies'>['data'];

const stripTags = (s: string | null | undefined) =>
  (s ?? '').replace(/<[^>]+>/g, '').trim();

const page = await getEntry('pages', 'about/oversight');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const entries = await getCollection('biographies');
const board: Bio[] = entries
  .map((e) => e.data)
  .filter((b: Bio) => b.category === 'oversight')
  .sort((a: Bio, b: Bio) =>
    (a.alphabetizeBy ?? a.lastName ?? '').localeCompare(
      b.alphabetizeBy ?? b.lastName ?? ''));
---
<BaseLayout title="Oversight Board"
            description="The Adult Redeploy Illinois Oversight Board guides program policy and reviews local-site funding decisions.">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home',  href: `${base}/` },
      { label: 'About', href: `${base}/about` },
      { label: 'Oversight Board' },
    ]} />
    <h1 class="text-page-title mt-4">Oversight Board</h1>
    {page && <Markdown content={page.data.content} class="mt-4" />}
    <ul class="mt-8 grid gap-6 md:grid-cols-2">
      {board.map((b: Bio) => {
        const name = [b.prefix, b.firstName, b.middleName, b.lastName, b.suffix]
                       .filter(Boolean).map((s) => s!.trim()).join(' ');
        const title = stripTags(b.title);
        const membership = stripTags(b.membership);
        const headshot = b.headshot ? getCmsImageByPath(b.headshot.url) : null;
        return (
          <li>
            <a href={`${base}/about/biographies/${b.slug}`}
               class="flex gap-4 p-4 border border-brand-muted/40 rounded
                      hover:shadow-elev1
                      focus-visible:outline focus-visible:outline-2
                      focus-visible:outline-brand-primary focus-visible:outline-offset-2">
              {headshot && (
                <img src={headshot.src}
                     srcset={headshot.srcset}
                     sizes="80px"
                     width={headshot.width}
                     height={headshot.height}
                     alt=""
                     loading="lazy"
                     decoding="async"
                     class="w-20 h-20 rounded object-cover shrink-0" />
              )}
              <div>
                <div class="font-bold text-brand-primary">{name}</div>
                {title && <div class="text-sm italic">{title}</div>}
                {membership && <div class="text-sm">{membership}</div>}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>
