---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Markdown from '../../components/Markdown.astro';
import { getCmsImageByPath } from '../../lib/cms-image';

type Bio = CollectionEntry<'biographies'>['data'];

// CMS titles arrive wrapped in <span class="heavy">…</span> from the legacy
// Nuxt CSS that defined a .heavy weight; we don't carry that class forward,
// so just unwrap to plain text and apply our own typography.
const stripTags = (s: string | null | undefined) =>
  (s ?? '').replace(/<[^>]+>/g, '').trim();

const page = await getEntry('pages', 'about/staff');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const entries = await getCollection('biographies');
const staff: Bio[] = entries
  .map((e) => e.data)
  .filter((b: Bio) => b.category === 'staff')
  .sort((a: Bio, b: Bio) =>
    (a.order ?? 999) - (b.order ?? 999) ||
    (a.lastName ?? '').localeCompare(b.lastName ?? ''));
---
<BaseLayout title="Staff"
            description="The Adult Redeploy Illinois staff team at the Illinois Criminal Justice Information Authority.">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home',  href: `${base}/` },
      { label: 'About', href: `${base}/about` },
      { label: 'Staff' },
    ]} />
    <h1 class="text-page-title mt-4">Staff</h1>
    {page && <Markdown content={page.data.content} class="mt-4" />}
    <ul class="mt-8 space-y-8">
      {staff.map((b: Bio) => {
        const name = [b.prefix, b.firstName, b.middleName, b.lastName, b.suffix]
                       .filter(Boolean).map((s) => s!.trim()).join(' ');
        const title = stripTags(b.title);
        const membership = stripTags(b.membership);
        const headshot = b.headshot ? getCmsImageByPath(b.headshot.url) : null;
        return (
          <li class="border border-brand-muted/40 rounded p-4 md:p-6 bg-surface">
            <div class="flex flex-col md:flex-row gap-4 md:gap-6">
              {headshot && (
                <div class="md:w-40 md:shrink-0">
                  <img src={headshot.src}
                       srcset={headshot.srcset}
                       sizes="(min-width: 768px) 160px, 50vw"
                       width={headshot.width}
                       height={headshot.height}
                       alt=""
                       loading="lazy"
                       decoding="async"
                       class="w-32 md:w-40 h-auto rounded shadow-elev1" />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <h2 class="font-heading font-bold text-xl">
                  <a href={`${base}/about/biographies/${b.slug}`}
                     class="tap-target text-brand-primary hover:underline
                            focus-visible:outline focus-visible:outline-2
                            focus-visible:outline-brand-primary focus-visible:outline-offset-2">
                    {name}
                  </a>
                </h2>
                {title && <p class="text-sm font-bold mt-1">{title}</p>}
                {membership && <p class="text-sm mt-1">{membership}</p>}
                {b.content && <Markdown content={b.content} class="mt-3 text-sm" />}
              </div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>
