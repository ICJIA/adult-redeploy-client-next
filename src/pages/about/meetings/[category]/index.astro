---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/ui/Breadcrumb.astro';
import ListingTable from '../../../../components/alpine/ListingTable.astro';
import { MEETING_CATEGORIES, type MeetingCategory } from '../../../../lib/meetings';
import { meetingsIndexRows, MTG_INDEX_SIG_KEYS } from '../../../../lib/live/render/listing-rows';
import { stableSignature } from '../../../../lib/live/behavior/signature';

type Meeting = CollectionEntry<'meetings'>['data'];

export async function getStaticPaths() {
  return MEETING_CATEGORIES.map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}
const { category } = Astro.props as { category: MeetingCategory };
const entries = await getCollection('meetings');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const ctx = { endpoint: '', basePath: base };
// All meetings in this category (no limit), live-refreshed — the shared builder
// drives both the static rows and the live swap, and sig baselines the build set.
const rows = meetingsIndexRows(entries.map((e): Meeting => e.data), ctx,
  { enum: category.enum, slug: category.slug });
const live = {
  surface: 'meetingsIndex',
  sig: stableSignature(rows, MTG_INDEX_SIG_KEYS),
  params: { enum: category.enum, slug: category.slug },
};
---
<BaseLayout title={category.title}
            description={`${category.title} — Adult Redeploy Illinois. ${rows.length} meeting${rows.length === 1 ? '' : 's'} on record.`}>
  <div class="max-w-6xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home',     href: `${base}/` },
      { label: 'About',    href: `${base}/about` },
      { label: 'Meetings', href: `${base}/about/meetings` },
      { label: category.short },
    ]} />
    <h1 class="text-page-title mt-4">{category.title}</h1>
    <div class="mt-8">
      <ListingTable ariaLabel={category.slug}
        columns={[
          { key: 'title',         label: 'Meeting Title' },
          { key: 'scheduledDate', label: 'Scheduled', format: 'date' },
        ]}
        rows={rows}
        live={live}
      />
    </div>
  </div>
</BaseLayout>
