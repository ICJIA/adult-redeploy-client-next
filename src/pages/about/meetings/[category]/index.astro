---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/ui/Breadcrumb.astro';
import ListingTable from '../../../../components/alpine/ListingTable.astro';
import { MEETING_CATEGORIES, type MeetingCategory } from '../../../../lib/meetings';

type Meeting = CollectionEntry<'meetings'>['data'];

export async function getStaticPaths() {
  return MEETING_CATEGORIES.map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}
const { category } = Astro.props as { category: MeetingCategory };
const entries = await getCollection('meetings');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const rows = entries
  .map((e) => e.data)
  .filter((m: Meeting) => m.category === category.enum)
  .sort((a: Meeting, b: Meeting) =>
    (a.scheduledDate ?? '') < (b.scheduledDate ?? '') ? 1 : -1)
  .map((m: Meeting) => ({
    title: m.title,
    scheduledDate: m.scheduledDate ?? '',
    href: `${base}/about/meetings/${category.slug}/${m.slug}`,
  }));
---
<BaseLayout title={category.title}
            description={`${category.title} — Adult Redeploy Illinois. ${rows.length} meeting${rows.length === 1 ? '' : 's'} on record.`}>
  <div class="max-w-6xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home',     href: `${base}/` },
      { label: 'About',    href: `${base}/about` },
      { label: 'Meetings', href: `${base}/about/meetings` },
      { label: category.short },
    ]} />
    <h1 class="text-page-title mt-4">{category.title}</h1>
    <div class="mt-8">
      <ListingTable ariaLabel={category.slug}
        columns={[
          { key: 'title',         label: 'Meeting Title' },
          { key: 'scheduledDate', label: 'Scheduled', format: 'date' },
        ]}
        rows={rows}
      />
    </div>
  </div>
</BaseLayout>
