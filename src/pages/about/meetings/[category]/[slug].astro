---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import Markdown from '../../../../components/Markdown.astro';
import Tag from '../../../../components/ui/Tag.astro';
import { formatDate } from '../../../../lib/dates';
import { MEETING_CATEGORIES, enumToSlug } from '../../../../lib/meetings';
import { MTG_DETAIL_SIG, renderMeetingMaterials } from '../../../../lib/live/render/meeting-detail';

type Meeting = CollectionEntry<'meetings'>['data'];

export async function getStaticPaths() {
  const items = await getCollection('meetings');
  return items
    .filter((m) => enumToSlug[m.data.category])
    .map((m) => ({
      params: {
        category: enumToSlug[m.data.category],
        slug: m.data.slug,
      },
      props: { item: m.data },
    }));
}
const { item } = Astro.props as { item: Meeting };
const category = MEETING_CATEGORIES.find((c) => c.enum === item.category)!;
const base = import.meta.env.BASE_URL || '/adultredeploy';
const xData = `liveEntry({ surface: 'meetingDetail', slug: ${JSON.stringify(item.slug)}, sig: ${JSON.stringify(MTG_DETAIL_SIG(item))} })`;
---
<BaseLayout title={item.title} description={item.summary ?? undefined}>
  <div x-data={xData}>
    <ArticleCard title={item.title}
                 badge={category.title}
                 pagefindMeta={{ type: 'meeting', date: item.scheduledDate ?? '' }}>
      <p class="text-sm font-bold text-brand-secondary uppercase mb-4" data-live="scheduled">
        Scheduled: {formatDate(item.scheduledDate)}
      </p>
      <Markdown content={item.content} dataLive="body" />
      <div data-live="materials" set:html={renderMeetingMaterials((item.meetingMaterial ?? []) as any[])}></div>
      {item.tags && item.tags.length > 0 && (
        <div class="mt-8 flex flex-wrap gap-2">
          {item.tags.map((t) => (
            <Tag label={t.name} href={`${base}/tags/${t.slug}`} />
          ))}
        </div>
      )}
    </ArticleCard>
  </div>
</BaseLayout>
