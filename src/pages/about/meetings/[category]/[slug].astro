---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import MeetingDetailShell from '../../../../components/MeetingDetailShell.astro';
import { MEETING_CATEGORIES, enumToSlug } from '../../../../lib/meetings';
import { MTG_DETAIL_SIG } from '../../../../lib/live/render/meeting-detail';
import { meetingEvent } from '../../../../lib/jsonld';

type Meeting = CollectionEntry<'meetings'>['data'];

export async function getStaticPaths() {
  const items = await getCollection('meetings');
  return items
    .filter((m) => enumToSlug[m.data.category])
    .map((m) => ({
      params: {
        category: enumToSlug[m.data.category],
        slug: m.data.slug,
      },
      props: { item: m.data },
    }));
}
const { item } = Astro.props as { item: Meeting };
const category = MEETING_CATEGORIES.find((c) => c.enum === item.category)!;
const base = import.meta.env.BASE_URL || '/adultredeploy';
const xData = `liveEntry({ surface: 'meetingDetail', slug: ${JSON.stringify(item.slug)}, sig: ${JSON.stringify(MTG_DETAIL_SIG(item))} })`;
const eventJsonLd = meetingEvent({
  url: `https://icjia.illinois.gov${base}/about/meetings/${category.slug}/${item.slug}`,
  name: item.title,
  description: item.summary,
  startDate: item.scheduledDate,
});
---
<BaseLayout title={item.title} description={item.summary ?? undefined}
            ogType="article" jsonLd={eventJsonLd}
            published={item.createdAt} modified={item.updatedAt}>
  <div x-data={xData}>
    <MeetingDetailShell item={item} />
  </div>
</BaseLayout>
