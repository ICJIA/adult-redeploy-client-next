---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTitle from '../../components/ui/PageTitle.astro';
import ListingTable from '../../components/alpine/ListingTable.astro';
import { sitesIndexRows, SITES_INDEX_SIG_KEYS } from '../../lib/live/render/listing-rows';
import { stableSignature } from '../../lib/live/behavior/signature';

const entries = await getCollection('sites');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const ctx = { endpoint: '', basePath: base };
// Shared row builder drives both the static table and the live refresh.
const rows = sitesIndexRows(entries.map((e) => e.data), ctx);
const live = { surface: 'sitesIndex', sig: stableSignature(rows, SITES_INDEX_SIG_KEYS) };
---
<BaseLayout title="Sites"
            description="Adult Redeploy Illinois currently funds sites in Illinois counties and judicial circuits across the state.">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <PageTitle title="Sites" />
    <ListingTable ariaLabel="sites"
      columns={[
        { key: 'title',    label: 'Site' },
        { key: 'siteType', label: 'Type' },
      ]}
      rows={rows}
      live={live}
    />
  </div>
</BaseLayout>
