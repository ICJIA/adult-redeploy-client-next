---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ListingTable from '../../components/alpine/ListingTable.astro';

type Site = CollectionEntry<'sites'>['data'];

const entries = await getCollection('sites');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const rows = entries
  .map((e) => e.data)
  .sort((a: Site, b: Site) => a.title.localeCompare(b.title))
  .map((s: Site) => ({
    title: s.title,
    siteType: s.siteType ?? '',
    href: `${base}/sites/${s.slug}`,
  }));
---
<BaseLayout title="Sites">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home', href: `${base}/` },
      { label: 'Sites' },
    ]} />
    <h1 class="text-page-title mt-4">Sites</h1>
    <p class="mt-3 text-lg">
      Adult Redeploy Illinois currently funds sites in {entries.length}
      Illinois counties and judicial circuits.
    </p>
    <div class="mt-8">
      <ListingTable ariaLabel="sites"
        columns={[
          { key: 'title',    label: 'Site' },
          { key: 'siteType', label: 'Type' },
        ]}
        rows={rows}
      />
    </div>
  </div>
</BaseLayout>
