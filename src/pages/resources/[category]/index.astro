---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import ListingTable from '../../../components/alpine/ListingTable.astro';
import { RESOURCE_CATEGORIES, type ResourceCategory } from '../../../lib/resources';

type Resource = CollectionEntry<'resources'>['data'];

export async function getStaticPaths() {
  return RESOURCE_CATEGORIES.map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}
const { category } = Astro.props as { category: ResourceCategory };
const entries = await getCollection('resources');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const rows = entries
  .map((e) => e.data)
  .filter((r: Resource) => r.category === category.enum)
  .sort((a: Resource, b: Resource) =>
    (a.publicationDate ?? '') < (b.publicationDate ?? '') ? 1 : -1)
  .map((r: Resource) => ({
    title: r.title,
    publicationDate: r.publicationDate ?? '',
    href: `${base}/resources/${category.slug}/${r.slug}`,
  }));
---
<BaseLayout title={category.title}>
  <div class="max-w-6xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home',      href: `${base}/` },
      { label: 'Resources', href: `${base}/resources` },
      { label: category.short },
    ]} />
    <h1 class="text-page-title mt-4">{category.title}</h1>
    <div class="mt-8">
      <ListingTable ariaLabel={category.slug}
        columns={[
          { key: 'title',           label: 'Title' },
          { key: 'publicationDate', label: 'Published', format: 'date' },
        ]}
        rows={rows}
      />
    </div>
  </div>
</BaseLayout>
