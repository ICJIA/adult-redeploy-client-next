---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Markdown from '../../../components/Markdown.astro';
import Tag from '../../../components/ui/Tag.astro';
import { formatDate } from '../../../lib/dates';
import { RESOURCE_CATEGORIES, resEnumToSlug } from '../../../lib/resources';

type Resource = CollectionEntry<'resources'>['data'];

interface MaterialFile { name?: string; url?: string; hash?: string; }
interface Material {
  name?: string; summary?: string; file?: MaterialFile; url?: string;
}

export async function getStaticPaths() {
  const items = await getCollection('resources');
  return items
    .filter((r) => resEnumToSlug[r.data.category])
    .map((r) => ({
      params: { category: resEnumToSlug[r.data.category], slug: r.data.slug },
      props: { item: r.data },
    }));
}
const { item } = Astro.props as { item: Resource };
const category = RESOURCE_CATEGORIES.find((c) => c.enum === item.category)!;
const base = import.meta.env.BASE_URL || '/adultredeploy';
const STRAPI_BASE = 'https://ari.icjia-api.cloud';
const mediaMaterial = (item.mediaMaterial ?? []) as Material[];
const externalMediaMaterial = (item.externalMediaMaterial ?? []) as Material[];
---
<BaseLayout title={item.title} description={item.summary ?? undefined}>
  <ArticleCard title={item.title}
               badge={category.title}
               pagefindMeta={{ type: 'resource', category: category.short }}>
    <p class="text-sm text-gray-700 mb-4">
      Published: {formatDate(item.publicationDate)}
    </p>
    {item.summary && <p class="text-lg mb-6">{item.summary}</p>}
    <Markdown content={item.content} />

    {mediaMaterial.length > 0 && (
      <div class="mt-8 bg-surface-shaded p-6 rounded">
        <h2 class="font-bold mb-3">Downloads</h2>
        <ul class="space-y-2">
          {mediaMaterial.filter((m) => m.file?.url).map((m) => (
            <li>
              <a href={`${STRAPI_BASE}${m.file!.url}`}
                 target="_blank" rel="noopener"
                 class="text-brand-primary font-bold underline hover:no-underline
                        focus-visible:outline focus-visible:outline-2
                        focus-visible:outline-brand-primary focus-visible:outline-offset-2">
                {m.name}
              </a>
              {m.summary && <p class="text-sm mt-1">{m.summary}</p>}
            </li>
          ))}
        </ul>
      </div>
    )}

    {externalMediaMaterial.length > 0 && (
      <div class="mt-6 bg-surface-shaded p-6 rounded">
        <h2 class="font-bold mb-3">External Links</h2>
        <ul class="space-y-2">
          {externalMediaMaterial.filter((m) => m.url).map((m) => (
            <li>
              <a href={m.url}
                 target="_blank" rel="noopener"
                 class="text-brand-primary font-bold underline hover:no-underline
                        focus-visible:outline focus-visible:outline-2
                        focus-visible:outline-brand-primary focus-visible:outline-offset-2">
                {m.name}
              </a>
              {m.summary && <p class="text-sm mt-1">{m.summary}</p>}
            </li>
          ))}
        </ul>
      </div>
    )}

    {item.tags && item.tags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {item.tags.map((t) => (
          <Tag label={t.name} href={`${base}/tags/${t.slug}`} />
        ))}
      </div>
    )}
  </ArticleCard>
</BaseLayout>
