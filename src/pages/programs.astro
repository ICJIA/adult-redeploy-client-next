---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import Markdown from '../components/Markdown.astro';
import SiteIllinois from '../components/SiteIllinois.astro';

// Defensive: there is currently no `programs/programs` CMS page, so this renders
// nothing — kept so a future CMS programs page would surface automatically. The
// page's live content is the county map below (SiteIllinois), whose side-panel
// site data refreshes from Strapi without a rebuild.
const page = await getEntry('pages', 'programs/programs');
const base = import.meta.env.BASE_URL || '/adultredeploy';
---
<BaseLayout title="Programs"
            description="Adult Redeploy Illinois funds community-based programs as alternatives to incarceration in counties and judicial circuits across Illinois.">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home', href: `${base}/` },
      { label: 'Programs' },
    ]} />
    <h1 class="text-page-title mt-4">Programs</h1>
    {page && <Markdown content={page.data.content} class="mt-4" />}
    <div class="mt-8">
      <SiteIllinois />
    </div>
  </div>
</BaseLayout>
