---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { enumToSlug } from '../../lib/meetings';
import { resEnumToSlug } from '../../lib/resources';

type Tag = CollectionEntry<'tags'>['data'];

interface TaggedItem {
  slug: string;
  title: string;
  category?: string;
  tags?: { name: string; slug: string }[] | null;
}

export async function getStaticPaths() {
  const tagEntries = await getCollection('tags');
  return tagEntries.map((t) => ({
    params: { slug: t.data.slug },
    props: { tag: t.data },
  }));
}
const { tag } = Astro.props as { tag: Tag };
const base = import.meta.env.BASE_URL || '/adultredeploy';

const withTag = (slug: string, items: TaggedItem[]) =>
  items.filter((x) => (x.tags ?? []).some((t) => t.slug === slug));

const news = withTag(
  tag.slug,
  (await getCollection('news')).map((e) => e.data as TaggedItem),
).map((n) => ({ title: n.title, href: `${base}/news/${n.slug}` }));

const meetings = withTag(
  tag.slug,
  (await getCollection('meetings')).map((e) => e.data as TaggedItem),
).map((m) => ({
  title: m.title,
  href: `${base}/about/meetings/${enumToSlug[m.category!] ?? m.category}/${m.slug}`,
}));

const resources = withTag(
  tag.slug,
  (await getCollection('resources')).map((e) => e.data as TaggedItem),
).map((r) => ({
  title: r.title,
  href: `${base}/resources/${resEnumToSlug[r.category!] ?? r.category}/${r.slug}`,
}));

const sections = [
  { label: 'News',      items: news },
  { label: 'Meetings',  items: meetings },
  { label: 'Resources', items: resources },
].filter((s) => s.items.length > 0);
---
<BaseLayout title={`Tag: ${tag.name}`}
            description={`News, meetings, and resources tagged "${tag.name}" on Adult Redeploy Illinois.`}>
  <div class="max-w-4xl mx-auto px-6 py-10">
    <Breadcrumb items={[
      { label: 'Home', href: `${base}/` },
      { label: `Tag: ${tag.name}` },
    ]} />
    <h1 class="text-page-title mt-4">{tag.name}</h1>
    {sections.length === 0 ? (
      <p class="mt-6 italic">No tagged content yet.</p>
    ) : (
      sections.map((section) => (
        <section class="mt-8">
          <h2 class="font-heading font-bold text-xl mb-3">{section.label}</h2>
          <ul class="space-y-2">
            {section.items.map((i) => (
              <li>
                <a href={i.href}
                   class="text-brand-primary underline hover:no-underline
                          focus-visible:outline focus-visible:outline-2
                          focus-visible:outline-brand-primary focus-visible:outline-offset-2">
                  {i.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}
  </div>
</BaseLayout>
