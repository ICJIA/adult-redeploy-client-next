---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/HomeHero.astro';
import HomeBoxes from '../components/HomeBoxes.astro';
import HomeMeetings from '../components/HomeMeetings.astro';
import HomeNews from '../components/HomeNews.astro';
import HomeArticles from '../components/HomeArticles.astro';
import Markdown from '../components/Markdown.astro';
import { getEntry } from 'astro:content';
import { ABOUT_SIG } from '../lib/live/render/home-about';

const homePage = await getEntry('pages', 'home/home');
const base = import.meta.env.BASE_URL || '/adultredeploy';
const aboutXData = `liveEntry({ surface: 'homeAbout', slug: 'home', sig: ${JSON.stringify(ABOUT_SIG(homePage?.data))} })`;
---
<BaseLayout title="Home"
            description="Adult Redeploy Illinois (ARI) is the Illinois state grant program—administered by ICJIA—that funds community-based alternatives to incarceration.">
  <HomeHero />
  <HomeBoxes />
  <div id="about"
       class="max-w-6xl mx-auto px-6 mt-12 grid gap-8 md:grid-cols-3 scroll-mt-24">
    <div class="md:col-span-2" x-data={aboutXData}>
      <h2 class="text-page-title">
        <a href={`${base}/about/overview`}
           class="text-brand-ink hover:text-brand-muted underline-offset-4 hover:underline
                  focus-visible:outline focus-visible:outline-2
                  focus-visible:outline-brand-primary focus-visible:outline-offset-2">
          ABOUT ADULT REDEPLOY ILLINOIS
        </a>
      </h2>
      {homePage && <Markdown content={homePage.data.content} class="mt-6" dataLive="body" />}
    </div>
    <aside>
      <HomeMeetings />
    </aside>
  </div>
  <div class="max-w-6xl mx-auto px-6 mt-16 grid gap-8 md:grid-cols-2">
    <HomeNews />
    <HomeArticles />
  </div>
</BaseLayout>
